flowchart TB
  U[User input domain] --> CLI[CLI or menu]
  CLI --> ARGS[Build args]
  ARGS --> P[Start pipeline]

  P --> RECON[ReconEngine]
  RECON --> DNS[DNS resolve]
  RECON --> NMAP[Port scan]
  RECON --> HTTPT[Pick HTTP target]
  RECON --> WAF[Detect WAF and tech]
  RECON --> SUB[Find subdomains]

  HTTPT --> TARGET[Primary target URL]
  TARGET --> SESSION[SessionManager login]
  SESSION --> CLIENT[HTTPClient session]

  CLIENT --> BASE[BaselineEngine]
  BASE --> CRAWL[Crawler]
  CRAWL --> PARAM[ParamDiscoverer]
  PARAM --> GRAPH[EndpointGraph]

  GRAPH --> PLAN_IN[Endpoint context]
  PLAN_IN --> AI_PLAN[AI plan endpoints]
  AI_PLAN --> PLAN_OUT[Prioritized endpoints]

  PLAN_OUT --> FUZZ[OWASPFuzzEngine]
  FUZZ --> TOOLS[Security tools]
  FUZZ --> RAWF[Raw findings]

  RAWF --> AI_CLASS[AI classification]
  AI_CLASS --> CORR[Correlator]
  CORR --> AI_FP[FP filter]
  AI_FP --> CLEAN[Confirmed findings]

  CLEAN --> REPORT[Reporter]
  REPORT --> OUT1[Findings JSON]
  REPORT --> OUT2[Scan log JSON]
  REPORT --> OUT3[Markdown report]
  REPORT --> OUT4[Docx report optional]

  subgraph AI_SERVICE
    OLL[Ollama model]
  end

  RECON --> OLL
  CRAWL --> OLL
  PLAN_IN --> OLL
  RAWF --> OLL

  OLL --> AI_PLAN
  OLL --> AI_CLASS
  OLL --> AI_FP
